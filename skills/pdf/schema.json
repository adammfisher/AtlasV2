      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blocks"],
        "properties": {
          "blocks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 14,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": { "type": "string", "enum": ["heading", "para", "table"] },
                "text": { "type": "string" },
                "headers": { "type": "array", "maxItems": 8, "items": { "type": "string" } },
                "rows": {
                  "type": "array",
                  "maxItems": 30,
                  "items": { "type": "array", "maxItems": 8, "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    }
  }
}
