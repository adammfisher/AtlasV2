{
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "slides"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 90 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["archetype", "title", "speaker_notes"],
        "properties": {
          "archetype": {
            "type": "string",
            "enum": [
              "title", "agenda", "section_divider", "content_bullets",
              "content_chart", "comparison", "big_stat", "quote",
              "timeline_process", "two_column", "table", "closing_cta"
            ]
          },
          "title": { "type": "string", "maxLength": 90 },
          "subtitle": { "type": "string", "maxLength": 120 },
          "speaker_notes": { "type": "string", "minLength": 1, "maxLength": 600 },
          "bullets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": { "type": "string", "minLength": 1, "maxLength": 90 }
          },
          "icons": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string",
              "enum": ["growth", "target", "people", "risk", "time", "money", "check", "idea", "globe", "gear"]
            }
          },
          "chart": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "categories", "series", "sort"],
            "properties": {
              "kind": { "type": "string", "enum": ["line", "bar", "pie"] },
              "categories": {
                "type": "array",
                "minItems": 2,
                "maxItems": 12,
                "items": { "type": "string", "maxLength": 30 }
              },
              "series": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "values"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1, "maxLength": 40 },
                    "values": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 12,
                      "items": { "type": "number" }
                    }
                  }
                }
              },
              "sort": { "type": "string", "enum": ["value_desc", "value_asc", "time", "given"] }
            }
          },
          "columns": {
            "type": "array",
            "minItems": 2,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["head", "items"],
              "properties": {
                "head": { "type": "string", "minLength": 1, "maxLength": 40 },
                "items": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 4,
                  "items": { "type": "string", "minLength": 1, "maxLength": 90 }
                }
              }
            }
          },
          "stat": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "label"],
            "properties": {
              "value": { "type": "string", "minLength": 1, "maxLength": 12 },
              "label": { "type": "string", "minLength": 1, "maxLength": 60 }
            }
          },
          "support": { "type": "string", "maxLength": 140 },
          "quote": { "type": "string", "minLength": 1, "maxLength": 220 },
          "attribution": { "type": "string", "minLength": 1, "maxLength": 60 },
          "steps": {
            "type": "array",
            "minItems": 3,
            "maxItems": 6,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label"],
              "properties": {
                "label": { "type": "string", "minLength": 1, "maxLength": 30 },
                "detail": { "type": "string", "maxLength": 60 }
              }
            }
          },
          "table": {
            "type": "object",
            "additionalProperties": false,
            "required": ["headers", "rows"],
            "properties": {
              "headers": {
                "type": "array",
                "minItems": 2,
                "maxItems": 7,
                "items": { "type": "string", "minLength": 1, "maxLength": 30 }
              },
              "rows": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 7,
                  "items": { "type": "string", "maxLength": 60 }
                }
              }
            }
          },
          "position_overrides": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["shape", "x_in", "y_in", "w_in", "h_in"],
              "properties": {
                "shape": { "type": "string", "enum": ["title", "body", "chart", "table", "stat", "visual"] },
                "x_in": { "type": "number", "minimum": 0.5, "maximum": 12.83 },
                "y_in": { "type": "number", "minimum": 0.5, "maximum": 7.0 },
                "w_in": { "type": "number", "minimum": 0.5, "maximum": 12.33 },
                "h_in": { "type": "number", "minimum": 0.3, "maximum": 6.5 }
              }
            }
          }
        },
        "allOf": [
          { "if": { "properties": { "archetype": { "const": "content_chart" } } }, "then": { "required": ["chart"] } },
          { "if": { "properties": { "archetype": { "const": "comparison" } } }, "then": { "required": ["columns"] } },
          { "if": { "properties": { "archetype": { "const": "big_stat" } } }, "then": { "required": ["stat"] } },
          { "if": { "properties": { "archetype": { "const": "quote" } } }, "then": { "required": ["quote", "attribution"] } },
          { "if": { "properties": { "archetype": { "const": "timeline_process" } } }, "then": { "required": ["steps"] } },
          { "if": { "properties": { "archetype": { "const": "table" } } }, "then": { "required": ["table"] } },
          { "if": { "properties": { "archetype": { "const": "content_bullets" } } }, "then": { "required": ["bullets"] } },
          { "if": { "properties": { "archetype": { "const": "agenda" } } }, "then": { "required": ["bullets"] } },
          { "if": { "properties": { "archetype": { "const": "two_column" } } }, "then": { "required": ["bullets"] } }
        ]
      }
    }
  }
}
