{
  "type": "object",
  "additionalProperties": false,
  "required": ["sheets"],
  "properties": {
    "sheets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "table_style", "columns", "rows"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 31 },
          "table_style": {
            "type": "string",
            "enum": [
              "TableStyleLight8", "TableStyleLight9", "TableStyleLight15",
              "TableStyleMedium2", "TableStyleMedium4", "TableStyleMedium9"
            ]
          },
          "columns": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["header", "format"],
              "properties": {
                "header": { "type": "string", "minLength": 1, "maxLength": 40 },
                "format": {
                  "type": "string",
                  "enum": ["text", "integer", "decimal", "currency", "percent", "date"]
                },
                "role": { "type": "string", "enum": ["input", "formula", "link", "external"] }
              }
            }
          },
          "rows": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["t"],
                    "properties": { "t": { "type": "string", "maxLength": 200 } }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["n"],
                    "properties": { "n": { "type": "number" } }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["f"],
                    "properties": { "f": { "type": "string", "pattern": "^=", "maxLength": 200 } }
                  },
                  { "type": "null" }
                ]
              }
            }
          }
        }
      }
    }
  }
}
