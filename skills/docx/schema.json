{
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "blocks"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "author": { "type": "string", "maxLength": 80 }
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 120,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["heading", "paragraph", "bulleted_list", "numbered_list", "table", "figure", "quote", "page_break"]
          },
          "level": { "type": "integer", "minimum": 1, "maximum": 3 },
          "text": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "minLength": 1, "maxLength": 300 }
          },
          "headers": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 40 }
          },
          "rows": {
            "type": "array",
            "minItems": 1,
            "maxItems": 30,
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": { "type": "string", "maxLength": 200 }
            }
          },
          "caption": { "type": "string", "minLength": 1, "maxLength": 200 },
          "chart": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "categories", "series"],
            "properties": {
              "kind": { "type": "string", "enum": ["line", "bar"] },
              "categories": {
                "type": "array",
                "minItems": 2,
                "maxItems": 12,
                "items": { "type": "string", "maxLength": 30 }
              },
              "series": {
                "type": "array",
                "minItems": 1,
                "maxItems": 4,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "values"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1, "maxLength": 40 },
                    "values": { "type": "array", "minItems": 2, "maxItems": 12, "items": { "type": "number" } }
                  }
                }
              }
            }
          },
          "attribution": { "type": "string", "maxLength": 80 }
        },
        "allOf": [
          { "if": { "properties": { "kind": { "const": "heading" } } }, "then": { "required": ["level", "text"] } },
          { "if": { "properties": { "kind": { "const": "paragraph" } } }, "then": { "required": ["text"] } },
          { "if": { "properties": { "kind": { "const": "bulleted_list" } } }, "then": { "required": ["items"] } },
          { "if": { "properties": { "kind": { "const": "numbered_list" } } }, "then": { "required": ["items"] } },
          { "if": { "properties": { "kind": { "const": "table" } } }, "then": { "required": ["headers", "rows"] } },
          { "if": { "properties": { "kind": { "const": "figure" } } }, "then": { "required": ["caption", "chart"] } },
          { "if": { "properties": { "kind": { "const": "quote" } } }, "then": { "required": ["text"] } }
        ]
      }
    }
  }
}
