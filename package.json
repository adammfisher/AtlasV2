{
  "name": "atlas-local-v2",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"pnpm --filter @atlas/server dev\" \"pnpm --filter @atlas/client dev\"",
    "build": "pnpm -r build",
    "lint": "eslint client/src server/src scripts --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "test:isolation": "tsx scripts/test/isolation.test.ts",
    "test:pipeline-validity": "tsx scripts/test/validity.test.ts",
    "test:stage3-e2e": "tsx scripts/test/stage3-e2e.test.ts",
    "test:stage4-gates": "tsx scripts/test/stage4-gates.test.ts",
    "test:stage4-smoke": "tsx scripts/test/stage4-smoke.ts",
    "mock:kc": "tsx scripts/test/mock-kc.ts",
    "test:memory-eval": "tsx scripts/test/memory-eval.ts",
    "test:behavior-block": "tsx scripts/test/orchestration/behavior-block.test.ts",
    "test:routing": "tsx scripts/test/orchestration/run-routing.ts",
    "test:e2e-brain": "tsx scripts/test/orchestration/run-e2e.ts",
    "test:design": "tsx scripts/test/design_eval.ts",
    "test:e2e": "playwright test",
    "test:polish": "tsx scripts/test/polish_eval.ts",
    "test:unit": "vitest run --passWithNoTests tests/unit tests/integration",
    "test:ui": "playwright test --project=ui-mocked",
    "test:live": "playwright test --project=live-smoke",
    "test:parity": "playwright test --project=parity-legacy",
    "test:evals": "tsx tests/evals/run-all.ts",
    "test:ceiling": "ATLAS_CEILING=1 tsx tests/evals/run-all.ts --ceiling",
    "test:validators": "runtimes/python/venv/bin/python tests/validators/selftest.py",
    "test:all": "pnpm test:unit && pnpm test:validators && pnpm test:ui && pnpm test:live && pnpm test:parity && pnpm test:evals",
    "test:report": "playwright show-report"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "10.0.3",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript-eslint": "8.61.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "11.10.0",
    "zod": "3.25.76"
  }
}
